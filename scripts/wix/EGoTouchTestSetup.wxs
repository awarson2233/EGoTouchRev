<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">
  <!-- 
    测试版本安装包声明区：
    包含完整的诊断上位机与测试工具。
  -->
  <Package Name="!(loc.ProductNameTest)" Manufacturer="!(loc.Manufacturer)" Version="1.9.9"
           UpgradeCode="434AC770-0762-431A-9ABC-DB2F9DB289AD" 
           Scope="perMachine"
           Language="!(loc.Language)">

    <!-- 支持自动覆盖升级 -->
    <MajorUpgrade DowngradeErrorMessage="!(loc.DowngradeError)" AllowSameVersionUpgrades="yes" />

    <UI>
      <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER" />
      <Publish Dialog="LicenseAgreementDlg" Control="Next" Event="NewDialog" Value="VerifyReadyDlg" Order="3" Condition="1" />
      <Publish Dialog="VerifyReadyDlg" Control="Back" Event="NewDialog" Value="LicenseAgreementDlg" Order="3" Condition="NOT Installed" />
    </UI>
    <WixVariable Id="WixUILicenseRtf" Value="!(loc.LicenseRtf)" />

    <MediaTemplate EmbedCab="yes" />

    <StandardDirectory Id="ProgramFiles6432Folder">
      <Directory Id="INSTALLFOLDER" Name="EGoTouchRev" />
    </StandardDirectory>

    <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
      
      <!-- 自动打包 VC++ ARM64 运行库进行 App-Local 部署 -->
      <Files Include="..\..\build\vcredist_arm64\*.dll" />

      <!-- 核心服务 -->
      <Component Id="EGoTouchServiceComp" Guid="FCF77309-64AC-4F98-8424-B1D6144D9757">
        <File Id="EGoTouchServiceEXE" Source="build\EGoTouchService.exe" KeyPath="yes" />
        
        <ServiceInstall 
            Id="EGoTouchServiceInstaller"
            Type="ownProcess"
            Name="EGoTouchService"
            DisplayName="!(loc.ServiceDisplayNameTest)"
            Description="!(loc.ServiceDescriptionTest)"
            Start="auto"           
            Account="LocalSystem"
            ErrorControl="normal" />
            
        <ServiceControl Id="StartWixService" Name="EGoTouchService" 
                        Start="install" 
                        Stop="both" 
                        Remove="uninstall" />
      </Component>

      <!-- 配置文件 -->
      <Component Id="ConfigFileComp" Guid="F9D704CD-80EE-4AE2-9BE7-1BBDA7AB7421">
        <File Id="ConfigFile" Source="scripts\config.ini" KeyPath="yes" />
      </Component>

      <!-- 测试版本增加内容：上位机 EGoTouchApp 和 测试工具 BtMcuTestTool -->
      <Component Id="EGoTouchAppComp" Guid="E198F02C-4BA7-4E90-B7FD-A99A0FA5EB21">
        <File Id="EGoTouchAppEXE" Source="build\EGoTouchApp.exe" KeyPath="yes" />
      </Component>

      <Component Id="BtMcuTestToolComp" Guid="5247FBFC-E500-47E4-BCE5-23FE9A0C3817">
        <File Id="BtMcuTestToolEXE" Source="build\BtMcuTestTool.exe" KeyPath="yes" />
      </Component>

    </ComponentGroup>

    <!-- 功能树 -->
    <Feature Id="MainFeature" Title="EGoTouch Core &amp; Tools" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
    </Feature>
  </Package>
</Wix>
